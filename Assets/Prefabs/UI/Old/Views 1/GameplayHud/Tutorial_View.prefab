  m_text: "\u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E, \u043A\u0430\u043A
    \u0432\u044B \u0443\u0431\u044A\u0435\u0442\u0435 \u0432\u0441\u0435\u0445 \u0432\u0440\u0430\u0433\u043E\u0432
    \u0432 \u0432\u043E\u043B\u043D\u0435, \u0431\u0443\u0434\u0435\u0442 \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u043E
