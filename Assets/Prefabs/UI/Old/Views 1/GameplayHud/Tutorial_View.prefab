  _russianText: "\u042D\u0442\u043E \u043A\u043D\u043E\u043F\u043A\u0430 \u0434\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0436\u0438\u0437\u043D\u0435\u0439 \u0432\u0430\u0448\u0435\u043C\u0443 \u0437\u0430\u043C\u043A\u0443.
