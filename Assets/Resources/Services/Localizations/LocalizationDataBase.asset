  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: WavePopUpTutorial_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: WavePopUpTutorial
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u0432\u044B \u0443\u0431\u044A\u0435\u0442\u0435 \u0432\u0441\u0435\u0445
    \u0432\u0440\u0430\u0433\u043E\u0432 \u0432 \u0432\u043E\u043B\u043D\u0435, \u0431\u0443\u0434\u0435\u0442
    \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u043E \u0432\u0441\u043F\u043B\u044B\u0432\u0430\u044E\u0449\u0435\u0435
    \u043E\u043A\u043D\u043E \u043E \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0438
    \u0432\u043E\u043B\u043D\u044B."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: After you kill all the enemies in the wave, a pop-up
    window will be shown about the completion of the wave.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Dalgadaki t\xFCm d\xFC\u015Fmanlar\u0131 \xF6ld\xFCrd\xFCkten
    sonra, dalgan\u0131n sona erdi\u011Fini g\xF6steren bir a\xE7\u0131l\u0131r pencere
    g\xF6sterilecektir."
  <TurkishSprite>k__BackingField: {fileID: 0}
--- !u!114 &3073514162943602889
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
