  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: BunkerTutorial_Description_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: BunkerTutorial_Description
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u042D\u0442\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0436\u0438\u0437\u043D\u0435\u0439 \u0432\u0430\u0448\u0435\u0433\u043E \u0437\u0430\u043C\u043A\u0430.
    \u0415\u0441\u043B\u0438 \u0432\u0440\u0430\u0433 \u0434\u043E\u0431\u0438\u0440\u0430\u0435\u0442\u0441\u044F
    \u0434\u043E \u043D\u0435\u0433\u043E, \u0442\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435
    \u0443\u043C\u0435\u043D\u044C\u0448\u0430\u0435\u0442\u0441\u044F \u043D\u0430
    \u043E\u0434\u043D\u0443 \u0436\u0438\u0437\u043D\u044C."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: This is the number of lives of your castle. If an enemy
    gets to him, his health is reduced by one life.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
