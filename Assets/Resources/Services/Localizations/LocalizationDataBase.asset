  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: EnemySpawnTutorialDescription_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: EnemySpawnTutorialDescription
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u042D\u0442\u0430 \u0448\u043A\u0430\u043B\u0430 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0438\u043D\u0434\u0435\u043A\u0441 \u0442\u0435\u043A\u0443\u0449\u0435\u0439
    \u0432\u043E\u043B\u043D\u044B \u0432\u0440\u0430\u0433\u043E\u0432 \u0438 \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u0443\u0431\u0438\u0442\u044C
    \u0434\u043E \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: This scale shows the index of the current wave of enemies
    and how many are left to kill before the next one.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Bu \xF6l\xE7ek, mevcut d\xFC\u015Fman dalgas\u0131n\u0131n
    endeksini ve bir sonrakine kadar ka\xE7 tane \xF6ld\xFCrmeniz gerekti\u011Fini
    g\xF6sterir."
  <TurkishSprite>k__BackingField: {fileID: 0}
