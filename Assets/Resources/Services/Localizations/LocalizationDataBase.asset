  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: GreetingTutorialDescription_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: GreetingTutorialDescription
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u0432\u044B \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442\u0435
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435, \u043B\u0438\u0431\u043E \u043D\u0435
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B\u0438 \u0435\u0433\u043E \u0432
    \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0438\u0439 \u0440\u0430\u0437,
    \u043F\u0440\u043E\u0439\u0434\u0438\u0442\u0435 \u0435\u0433\u043E \u0434\u043E
    \u043A\u043E\u043D\u0446\u0430, \u0447\u0442\u043E\u0431\u044B \u043E\u043D\u043E
    \u0443 \u0432\u0430\u0441 \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435 \u043F\u043E\u044F\u0432\u043B\u044F\u043B\u043E\u0441\u044C."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: Since this is your first time taking the training, or
    you did not complete it the previous time, go through it to the end so that you
    no longer have it.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "E\u011Fitimi ilk kez ald\u0131\u011F\u0131n\u0131z veya
    bir \xF6nceki sefer tamamlamad\u0131\u011F\u0131n\u0131z i\xE7in, bir daha size
    gelmemesi i\xE7in sonuna kadar tamamlay\u0131n."
  <TurkishSprite>k__BackingField: {fileID: 0}
