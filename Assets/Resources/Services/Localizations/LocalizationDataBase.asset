  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: WalletTutorialDescription_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: WalletTutorialDescription
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u042D\u0442\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0432\u0430\u0448\u0438\u0445 \u0447\u0435\u0440\u0435\u043F\u043E\u0432. \u0417\u0430
    \u043A\u0430\u0436\u0434\u043E\u0435 \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u043E
    \u0437\u043E\u043C\u0431\u0438 \u0432\u044B \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0447\u0435\u0440\u0435\u043F\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432 \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u043C \u0432\u044B
    \u043C\u043E\u0436\u0435\u0442\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u0434\u043B\u044F \u043F\u043E\u043A\u0443\u043F\u043A\u0438 \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u0439."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: This is the number of your skulls. For every zombie you
    kill, you receive a certain number of skulls, which you can later use to purchase
    upgrades.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Bu sizin kafataslar\u0131n\u0131z\u0131n say\u0131s\u0131d\u0131r.
    \xD6ld\xFCrd\xFC\u011F\xFCn\xFCz her zombi i\xE7in belirli say\u0131da kafatas\u0131
    al\u0131rs\u0131n\u0131z ve bunlar\u0131 daha sonra y\xFCkseltme sat\u0131n almak
    i\xE7in kullanabilirsiniz."
  <TurkishSprite>k__BackingField: {fileID: 0}
