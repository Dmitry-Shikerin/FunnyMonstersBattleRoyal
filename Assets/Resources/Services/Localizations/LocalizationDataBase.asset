--- !u!114 &-1509137246326993814
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: AbilitiesTutorial_Description_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: AbilitiesTutorial_Description
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u042D\u0442\u043E \u0432\u0430\u0448\u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    . \u041F\u0435\u0440\u0432\u0430\u044F - \u0441\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u0435\u0442
    \u0431\u043E\u043C\u0431\u0443 \u043D\u0430 \u0432\u0440\u0430\u0433\u043E\u0432.
    \u0412\u0442\u043E\u0440\u0430\u044F - \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u0432\u0441\u0435\u0445 \u0432\u0430\u0448\u0438\u0445 \u0431\u043E\u0439\u0446\u043E\u0432.\u0422\u0440\u0435\u0442\u044C\u044F
    - \u0430\u043A\u0442\u0438\u0432\u0438\u0440\u0443\u0435\u0442 \u043E\u0433\u043D\u0435\u043C\u0435\u0442."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: These are your abilities. The first is to drop a bomb
    on the enemies. The second one restores all your fighters.The third one activates
    the flamethrower.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Bunlar sizin yetenekleriniz . Birincisi, d\xFC\u015Fmanlara
    bomba atmakt\u0131r. \u0130kincisi - t\xFCm sava\u015F\xE7\u0131lar\u0131n\u0131z\u0131
    geri y\xFCkler.\xDC\xE7\xFCnc\xFCs\xFC - alev makinesini etkinle\u015Ftirir."
  <TurkishSprite>k__BackingField: {fileID: 0}
--- !u!114 &-1169646632141698292
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
