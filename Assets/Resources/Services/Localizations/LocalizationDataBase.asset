  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: OpenLeaderboard_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: OpenLeaderboard
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u0414\u043B\u044F \u0442\u043E\u0433\u043E, \u0447\u0442\u043E\u0431\u044B
    \u043E\u0442\u043A\u0440\u044B\u0442\u044C \u0442\u0430\u0431\u043B\u0438\u0446\u0443
    \u043B\u0438\u0434\u0435\u0440\u043E\u0432, \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
    \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F.
    \u0412\u044B \u0445\u043E\u0442\u0438\u0442\u0435 \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F?"
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: To open the leaderboard, you need to log in. Do you want
    to log in?
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Liderlik tablosunu a\xE7mak i\xE7in giris yapman\u0131z
    gerekir. Giris yapmak ister misiniz?"
  <TurkishSprite>k__BackingField: {fileID: 0}
--- !u!114 &7449828143545975863
MonoBehaviour:
  m_ObjectHideFlags: 0
