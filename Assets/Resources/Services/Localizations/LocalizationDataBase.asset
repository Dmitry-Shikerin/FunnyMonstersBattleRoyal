  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: ScoreTutorialDescription_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: ScoreTutorialDescription
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u042D\u0442\u043E \u0448\u043A\u0430\u043B\u0430 \u0432\u0430\u0448\u0438\u0445
    \u043E\u0447\u043A\u043E\u0432 \u0437\u0430 \u043A\u0430\u0436\u0434\u043E\u0433\u043E
    \u0443\u0431\u0438\u0442\u043E\u0433\u043E \u0432\u0440\u0430\u0433\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u043E\u0442\u0440\u0430\u0442\u0438\u0442\u044C
    \u043D\u0430 \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u0435  \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439"
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: This is a scale of your points for each enemy you kill,
    which you can spend on improving your abilities.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Bu, yetenekleri geli\u015Ftirmek i\xE7in harcayabilece\u011Finiz
    \xF6ld\xFCr\xFClen her d\xFC\u015Fman i\xE7in puanlar\u0131n\u0131z\u0131n \xF6l\xE7e\u011Fidir."
  <TurkishSprite>k__BackingField: {fileID: 0}
