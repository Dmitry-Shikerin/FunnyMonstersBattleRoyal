  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: FirstAidKitTutorialDescription_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: FirstAidKitTutorialDescription
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u042D\u0442\u043E \u0441\u043F\u0430\u0432\u043D\u0435\u0440\u044B,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043C\u043E\u0436\u0435\u0442
    \u0437\u0430\u0441\u043F\u0430\u0432\u043D\u0438\u0442\u044C\u0441\u044F \u0430\u043F\u0442\u0435\u0447\u043A\u0430.
    \u041D\u0430 \u043E\u0434\u043D\u043E\u0439 \u043B\u043E\u043A\u0430\u0446\u0438\u0438
    \u0438\u0445 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E,
    \u0442\u043E\u0433\u0434\u0430 \u0430\u043F\u0442\u0435\u0447\u043A\u0430 \u0431\u0443\u0434\u0435\u0442
    \u0441\u043F\u0430\u0432\u043D\u0438\u0442\u044C\u0441\u044F \u0440\u0430\u043D\u0434\u043E\u043C\u043D\u043E.
    \u041A\u0430\u0436\u0434\u0430\u044F \u0430\u043F\u0442\u0435\u0447\u043A\u0430
    \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0432\u0430\u0435\u0442 \u0432\u0430\u0448\u0435
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: These are the spawners on which the first-aid kit can
    spawn. There may be several of them at one location, then the first-aid kit will
    be spawned randomly. Each first aid kit increases your health.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Bunlar, \xFCzerine ilk yard\u0131m \xE7antas\u0131n\u0131n
    uyuyabilece\u011Fi yumurtlay\u0131c\u0131lard\u0131r. Bir yerde bunlardan birka\xE7\u0131
    olabilir, o zaman ilk yard\u0131m \xE7antas\u0131 rastgele do\u011Facakt\u0131r.
    Her ilk yard\u0131m \xE7antas\u0131 sa\u011Fl\u0131\u011F\u0131n\u0131z\u0131
    art\u0131r\u0131r."
  <TurkishSprite>k__BackingField: {fileID: 0}
