  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: ScullsDiggerDescription
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u041D\u0430\u043A\u043E\u043F\u0438\u0442\u0435 100
    \u0447\u0435\u0440\u0435\u043F\u043E\u0432 \u0432 \u0438\u0433\u0440\u0435."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: Collect 100 skulls in the game.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Oyunda 100 kafatas\u0131 biriktirin."
  <TurkishSprite>k__BackingField: {fileID: 0}
--- !u!114 &8224070170877804161
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: AdTutorialDescription_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: AdTutorialDescription
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u041F\u0440\u0438 \u043D\u0430\u0436\u0430\u0442\u0438\u0438
    \u043D\u0430 \u044D\u0442\u0443 \u043A\u043D\u043E\u043F\u043A\u0443 , \u0432
    \u043E\u043A\u043D\u0435 \u043F\u0430\u0443\u0437\u044B \u0438 \u0432 \u0433\u043B\u0430\u0432\u043D\u043E\u043C
    \u043C\u0435\u043D\u044E, \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    5 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0436\u0438\u0437\u043D\u0435\u0439. \u0422\u0430\u043A\u0436\u0435 \u0440\u0435\u043A\u043B\u0430\u043C\u0430
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0441\u043B\u0435
    \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F \u043A\u0430\u0436\u0434\u044B\u0445
    20 \u0432\u043E\u043B\u043D. \u0415\u0441\u043B\u0438 \u0443 \u0432\u0430\u0441
    \u0432\u043A\u043B\u044E\u0447\u0435\u043D AdBlock, \u0442\u043E \u0440\u0435\u043A\u043B\u0430\u043C\u0430
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C\u0441\u044F \u043D\u0435
    \u0431\u0443\u0434\u0435\u0442."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: By clicking on this button, in the pause window and in
    the main menu, you can get 5 additional lives. Ads are also shown after every
    20 waves are completed. If you have AdBlock enabled, then ads will not be displayed.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Bu d\xFC\u011Fmeye bast\u0131\u011F\u0131n\u0131zda,
    duraklatma penceresinde ve ana men\xFCde 5 ek can alabilirsiniz. Ayr\u0131ca,
    her 20 dalgan\u0131n tamamlanmas\u0131ndan sonra reklamlar g\xF6sterilir. Adblock'u
    etkinle\u015Ftirdiyseniz, reklam g\xF6sterilmeyecektir."
  <TurkishSprite>k__BackingField: {fileID: 0}
