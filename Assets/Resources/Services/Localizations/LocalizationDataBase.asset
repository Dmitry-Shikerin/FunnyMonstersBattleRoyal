  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: UpgradeTopAbilitiesDescription_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: UpgradeTopAbilitiesDescription
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u042D\u0442\u043E \u043A\u043D\u043E\u043F\u043A\u0438
    \u043F\u0440\u043E\u043A\u0430\u0447\u043A\u0438 \u0432\u0430\u0448\u0438\u0445
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439. \u041A\u0430\u0436\u0434\u0430\u044F
    \u043F\u0440\u043E\u043A\u0430\u0447\u043A\u0430 \u043E\u0442\u043D\u0438\u043C\u0430\u0435\u0442
    \u0443 \u0432\u0430\u0441 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043E\u0447\u043A\u043E\u0432. \u041C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0439
    \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u043F\u0440\u043E\u043A\u0430\u0447\u043A\u0438
    - \u0434\u0435\u0441\u044F\u0442\u044B\u0439."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: These are the buttons for leveling up your abilities.
    Each upgrade takes away a number of points from you. The maximum leveling level
    is the tenth.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Bunlar yeteneklerinizi seviyelendirme d\xFC\u011Fmeleridir.
    Her pompalama sizden puan say\u0131s\u0131n\u0131 al\u0131r. Maksimum pompalama
    seviyesi onuncu seviyededir."
  <TurkishSprite>k__BackingField: {fileID: 0}
