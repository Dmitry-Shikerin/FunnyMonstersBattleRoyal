--- !u!114 &4153720819052683178
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f9b47770bff74a2d91593ebd8dcce095, type: 3}
  m_Name: HealthBooster_Description_Phrase
  m_EditorClassIdentifier: 
  _headere: <size=18><b><color=#FF7F50><i>UiLocalizationPhrase</i></color></b></size>
  _editParent: 0
  <Parent>k__BackingField: {fileID: 11400000}
  <Scope>k__BackingField: {fileID: 0}
  <LocalizationId>k__BackingField: HealthBooster_Description
  <TextId>k__BackingField: 
  _editRussian: 0
  <Russian>k__BackingField: "\u042D\u0442\u043E \u043A\u043D\u043E\u043F\u043A\u0430
    \u0434\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u0438\u044F \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0436\u0438\u0437\u043D\u0435\u0439 \u0432\u0430\u0448\u0435\u043C\u0443 \u0437\u0430\u043C\u043A\u0443.
    \u041F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0436\u0438\u0437\u043D\u0438 \u043C\u043E\u0436\u043D\u043E, \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0432
    \u0440\u0435\u043A\u043B\u0430\u043C\u0443 \u0438\u043B\u0438 \u043E\u0442\u043A\u0440\u044B\u0432
    \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u0443\u044E \u043D\u0430\u0433\u0440\u0430\u0434\u0443."
  <RussianSprite>k__BackingField: {fileID: 0}
  _editEnglish: 0
  <English>k__BackingField: This is the button to add extra lives to your castle.
    You can get extra lives by watching an advertisement or opening a daily reward.
  <EnglishSprite>k__BackingField: {fileID: 0}
  _editTurkish: 0
  <Turkish>k__BackingField: "Bu, kalenize ekstra can eklemek i\xE7in bir d\xFC\u011Fmedir.
    Bir reklam izleyerek veya g\xFCnl\xFCk \xF6d\xFCl\xFCn\xFCz\xFC a\xE7arak ekstra
    can kazanabilirsiniz."
  <TurkishSprite>k__BackingField: {fileID: 0}
--- !u!114 &4826722777252017251
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
